{
  "name": "orangehrm-playwright-automation",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
      "test": "cucumber-js src/features -p default",
      "posttest": "npm run report",
      "test:headed": "cross-env HEADED=true cucumber-js src/features -p default",
      "test:chrome": "cross-env BROWSER=chromium cucumber-js src/features -p chromium",
      "test:firefox": "cross-env BROWSER=firefox cucumber-js src/features -p firefox",
      "test:webkit": "cross-env BROWSER=webkit cucumber-js src/features -p webkit",
      "test:tag": "cucumber-js src/features -p default --tags",
      "test:smoke": "cucumber-js src/features -p default --tags @smoke",
      "posttest:smoke": "npm run report",
      "test:regression": "cucumber-js src/features -p default --format progress-bar",
      "posttest:regression": "npm run report",
      "test:pim": "cucumber-js src/features/pim.feature -p chromium --tags \"not @skip\"",
      "test:cross-browser": "npm run test:chrome -- --tags \"not @skip\" && npm run test:firefox -- --tags \"not @skip\" && npm run test:webkit -- --tags \"not @skip\"",
      "report": "node src/utils/generate-report.js",
      "docker:build": "docker compose build",
      "docker:test": "docker compose up --abort-on-container-exit",
      "docker:test:smoke": "docker compose run playwright-tests npm run test:smoke",
      "docker:clean": "docker compose down -v"
    },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "multiple-cucumber-html-reporter": "^3.9.3",
    "ts-node": "^10.9.2"
  }
}
