{
  "default": {
    "require": ["src/steps/**/*.ts", "src/hooks/**/*.ts"],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress-bar",
      "html:reports/cucumber-report.html",
      "json:reports/cucumber-report.json"
    ],
    "formatOptions": { "snippetInterface": "async-await" },
    "parallel": 2,
    "retry": 0,
    "strict": true
  },
  "chromium": {
    "require": ["src/steps/**/*.ts", "src/hooks/**/*.ts"],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress-bar",
      "html:reports/cucumber-chromium.html",
      "json:reports/cucumber-chromium.json"
    ],
    "formatOptions": { "snippetInterface": "async-await" },
    "parallel": 1,
    "retry": 0,
    "strict": true,
    "worldParameters": { "browser": "chromium" }
  },
  "firefox": {
    "require": ["src/steps/**/*.ts", "src/hooks/**/*.ts"],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress-bar",
      "html:reports/cucumber-firefox.html",
      "json:reports/cucumber-firefox.json"
    ],
    "formatOptions": { "snippetInterface": "async-await" },
    "parallel": 1,
    "retry": 0,
    "strict": true,
    "worldParameters": { "browser": "firefox" }
  },
  "webkit": {
    "require": ["src/steps/**/*.ts", "src/hooks/**/*.ts"],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress-bar",
      "html:reports/cucumber-webkit.html",
      "json:reports/cucumber-webkit.json"
    ],
    "formatOptions": { "snippetInterface": "async-await" },
    "parallel": 1,
    "retry": 0,
    "strict": true,
    "worldParameters": { "browser": "webkit" }
  }
}