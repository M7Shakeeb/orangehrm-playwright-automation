{
  "default": {
    "paths": [
      "src/features/**/*.feature"
    ],
    "require": [
      "src/steps/**/*.ts",
      "src/hooks/**/*.ts"
    ],
    "requireModule": ["ts-node/register"],
    "format": [
      "progress-bar",
      "html:reports/cucumber-report.html",
      "json:reports/cucumber-report.json"
    ],
    "formatOptions": {
      "snippetInterface": "async-await"
    },
    "parallel": 1
  }
}